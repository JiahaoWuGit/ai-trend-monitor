# === AI Trend Monitor — 环境变量 ===

# DashScope API key（Qwen 模型，用于生成摘要）
# 获取: https://bailian.console.aliyun.com/ → API-KEY 管理
DASHSCOPE_API_KEY=sk-...

# Resend API key（用于发邮件）
# 获取: https://resend.com（免费 100 封/天）
RESEND_API_KEY=re_...

# 邮件接收地址
EMAIL_TO=your-email@example.com

# 邮件发送地址（需在 Resend 验证域名，或用默认测试地址）
EMAIL_FROM=onboarding@resend.dev
